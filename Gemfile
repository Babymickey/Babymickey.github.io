source "https://rubygems.org"

# Use the GitHub Pages gem to handle Jekyll and all standard plugins
gem "github-pages", group: :jekyll_plugins

# Necessary for the portfolYOU theme features
gem 'jekyll-archives'
gem 'jekyll-paginate-v2'
gem "mini_magick"
gem "kramdown-parser-gfm"

# Required for Ruby 3.x/4.x compatibility on Windows/GitHub
gem 'webrick'
gem "rexml"
gem "csv"
gem "base64"
gem 'bigdecimal'

# Windows compatibility
gem 'tzinfo-data', platforms: [:mingw, :mswin, :x64_mingw, :jruby]
